# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Google OAuth (OSS Google Login)
GOOGLE_CLIENT_ID=your_google_client_id_here

# SMTP (default: Hostinger; configurable at runtime via Admin Settings)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@yourdomain.com
SMTP_PASS=your_smtp_password_her
SMTP_FROM=info@yourdomain.com

# Google Analytics 4
GA_MEASUREMENT_ID=your_google_analytics_measurement_id_here
GA_CLIENT_ID=your_google_analytics_oauth_client_id_here
GA_CLIENT_SECRET=your_google_analytics_oauth_client_secret_here
GA_REFRESH_TOKEN=your_google_analytics_oauth_refresh_token_here

# Sentry Error Tracking
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENVIRONMENT=production

# Application
NODE_ENV=production
PORT=3000
APP_URL=https://yourdomain.com
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_aes256_encryption_key_here

# Blockchain API (TRC-20 / BEP-20) - managed at runtime via Admin Settings
# These are bootstrap defaults only; live values are stored in Supabase
TRC20_API_BASE_URL=https://api.trongrid.io
TRC20_API_KEY=your_trc20_api_key_here
TRC20_WALLET_ADDRESS=your_trc20_wallet_address_here
BEP20_API_BASE_URL=https://api.bscscan.com
BEP20_API_KEY=your_bep20_api_key_here
BEP20_WALLET_ADDRESS=your_bep20_wallet_address_here
